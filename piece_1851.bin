                return;
            }
            if (web_ui_username.includes(":")) {
                alert("QBT_TR(The WebUI username must not contain a colon.)QBT_TR[CONTEXT=OptionsDialog]");
                return;
            }
            const web_ui_password = document.getElementById("webui_password_text").value;
