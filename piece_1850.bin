                    const dateFormatSelect = document.getElementById("dateFormatSelect");
                    for (const format of Object.keys(window.qBittorrent.Misc.DateFormatOptions)) {
                        const option = document.createElement("option");
                        option.value = format;
                        option.textContent = window.qBittorrent.Misc.formatDate(now, format);
                        option.selected = format === dateFormat;
                        dateFormatSelect.appendChild(opti